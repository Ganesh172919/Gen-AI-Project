# FaithForge Environment Configuration
# Copy this to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=FaithForge
DEBUG=true
LOG_LEVEL=INFO

# Logging format: "text" for human-readable (dev), "json" for structured (prod)
LOG_FORMAT=text

# File logging (optional — leave empty to log to console only)
# LOG_FILE_PATH=./logs/faithforge.log
# LOG_MAX_BYTES=10000000
# LOG_BACKUP_COUNT=7

# ── LLM API Keys (get free tiers from each provider) ────────────────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: groq, cerebras, openrouter
LLM_PROVIDER=groq
GENERATOR_MODEL=llama-3.3-70b-versatile
GENERATOR_TEMPERATURE=0.3
GENERATOR_MAX_TOKENS=2048

# ── Vector Store ────────────────────────────────────────────────────────────
# Options: chromadb, pgvector
VECTOR_STORE_TYPE=chromadb
CHROMADB_PATH=./data/chromadb
PGVECTOR_URL=postgresql://faithforge:faithforge@localhost:5432/faithforge
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Retriever ───────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANKER_TOP_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
BM25_INDEX_PATH=./data/bm25_index.pkl

# ── Verifier ────────────────────────────────────────────────────────────────
VERIFIER_MODEL_PATH=./models/verifier
VERIFIER_BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
VERIFIER_MAX_ITERATIONS=3
VERIFIER_CONFIDENCE_THRESHOLD=0.7

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=faithforge-backend

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
